#!/usr/bin/env bash
# anvil-runtime — standalone-NeLisp MCP launcher for anvil.el.
#
# Loads anvil-server.el modules under a standalone NeLisp interpreter
# and enters the MCP Content-Length stdio loop via the elisp driver in
# `scripts/anvil-runtime-shell-loop.el'.  Migrated 2026-05-14 from
# `nelisp/bin/anvil-runtime' + `nelisp-emacs/scripts/anvil-runtime-*'
# so the entire deployment surface lives in this repo; `nelisp' and
# `nelisp-emacs' supply only the language runtime and Emacs C → elisp
# substrate respectively.
#
# Required env / paths:
#   ANVIL_EL_DIR        — anvil.el checkout root (default: this script's
#                         repo root, i.e. `$script_dir/..').
#   NELISP_BIN          — nelisp standalone binary.  Default: walks the
#                         sibling-checkout convention
#                         `$ANVIL_EL_DIR/../nelisp/target/release/nelisp'.
#   NELISP_EMACS_DIR    — nelisp-emacs checkout root.  Default: walks
#                         the sibling-checkout convention
#                         `$ANVIL_EL_DIR/../nelisp-emacs'.
#   ANVIL_SERVER_ID     — server-id (default: "default")
#
# Sibling-checkout convention assumed at default:
#   <parent>/
#     ├── anvil.el          (this repo)
#     ├── nelisp            (Layer 1 NeLisp runtime)
#     └── nelisp-emacs      (Layer 2 Emacs C → elisp port)
# Set the env vars above to override when the layout differs.

set -euo pipefail

ANVIL_RUNTIME_VERSION="0.7.0-anvil-el"

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ANVIL_EL_DIR="${ANVIL_EL_DIR:-$(cd "$script_dir/.." && pwd)}"

NELISP_BIN="${NELISP_BIN:-$(cd "$ANVIL_EL_DIR/../nelisp" 2>/dev/null && pwd || true)/target/release/nelisp}"
NELISP_EMACS_DIR="${NELISP_EMACS_DIR:-$(cd "$ANVIL_EL_DIR/../nelisp-emacs" 2>/dev/null && pwd || true)}"
LOOP_EL="${LOOP_EL:-$ANVIL_EL_DIR/scripts/anvil-runtime-shell-loop.el}"
SERVER_LOOP_EL="${SERVER_LOOP_EL:-$ANVIL_EL_DIR/scripts/anvil-runtime-server-loop.el}"

export ANVIL_EL_DIR NELISP_EMACS_DIR

usage() {
    cat >&2 <<EOF
usage: anvil-runtime --version
       anvil-runtime mcp serve              (Phase B5 stdio loop, single-client)
       anvil-runtime server [SOCKET_PATH]   (K2 UNIX-socket loop, multi-client)
EOF
    exit 2
}

if [ "$#" -lt 1 ]; then
    usage
fi

case "$1" in
    --version)
        echo "anvil-runtime $ANVIL_RUNTIME_VERSION"
        exit 0
        ;;
    mcp)
        if [ "$#" -ge 2 ] && [ "$2" = "serve" ]; then
            if [ ! -x "$NELISP_BIN" ]; then
                echo "anvil-runtime: nelisp binary not found at $NELISP_BIN" >&2
                exit 1
            fi
            if [ ! -f "$LOOP_EL" ]; then
                echo "anvil-runtime: loop driver not found at $LOOP_EL" >&2
                exit 1
            fi
            exec "$NELISP_BIN" exec "$LOOP_EL"
        fi
        usage
        ;;
    server)
        if [ ! -x "$NELISP_BIN" ]; then
            echo "anvil-runtime: nelisp binary not found at $NELISP_BIN" >&2
            exit 1
        fi
        if [ ! -f "$SERVER_LOOP_EL" ]; then
            echo "anvil-runtime: server loop not found at $SERVER_LOOP_EL" >&2
            exit 1
        fi
        # NeLisp Phase 1.6's `getenv' is a stub returning nil; we cannot
        # pass the socket path via OS env.  Synthesise a tiny bootstrap
        # elisp file that `setq's the path and then loads the real
        # server loop.  The file lives next to the socket itself so
        # `anvil-runtime-daemon stop' cleans it up alongside the socket.
        SOCKET_PATH="${2:-$HOME/.anvil-runtime/sock}"
        SOCKET_DIR="$(dirname "$SOCKET_PATH")"
        mkdir -p "$SOCKET_DIR"
        BOOTSTRAP="$SOCKET_DIR/bootstrap.el"
        cat > "$BOOTSTRAP" <<EOF
;; anvil-runtime server bootstrap (auto-generated by bin/anvil-runtime)
(setq anvil-runtime-bootstrap-socket-path "$SOCKET_PATH")
(load "$SERVER_LOOP_EL" nil t)
EOF
        exec "$NELISP_BIN" exec "$BOOTSTRAP"
        ;;
    *)
        usage
        ;;
esac
